# SPDX-License-Identifier: 0BSD

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

[*.md]
# Trailing whitespace has meaning in Markdown.
trim_trailing_whitespace = false

[{*.yml,*.yaml}]
indent_size = 2
#indent_style = space

[Makefile]
# Must use tabs for indentation in Makefile.
indent_style = tab
